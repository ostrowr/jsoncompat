{
  "openapi": "3.1.0",
  "info": {
    "title": "Nested unsupported pattern enum API",
    "version": "1.0.0"
  },
  "paths": {
    "/payload": {
      "get": {
        "responses": {
          "200": {
            "description": "payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "value": {
                      "type": "string",
                      "pattern": "^\\cC$"
