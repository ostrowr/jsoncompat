[
  {
    "description": "local ref to #/if survives canonicalization when then/else are omitted",
    "schema": {
      "allOf": [
        {
          "$ref": "#/if"
        }
      ],
      "if": {
        "type": "string"
      }
    }
  },
  {
    "description": "local ref to #/not survives canonicalization when not: false is simplified",
    "schema": {
      "if": false,
      "then": {
        "$ref": "#/not"
      },
      "not": false
    }
  },
  {
    "description": "indexed allOf refs remain valid when duplicate branches are present",
    "schema": {
      "allOf": [
        {
          "$ref": "#/x/allOf/1/properties/value"
        }
      ],
      "x": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "value": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "properties": {
              "value": {
                "type": "string"
              }
            }
          }
        ]
      }
    }
  },
  {
    "description": "refs into unsatisfiable descendants remain valid",
    "schema": {
      "allOf": [
        {
          "$ref": "#/x/allOf/0/properties/value"
        }
      ],
      "x": {
        "allOf": [
          {
            "type": "object",
            "properties": {
              "value": {
                "type": "string"
              }
            },
            "minProperties": 2,
            "maxProperties": 1
          }
        ]
      }
    }
  },
  {
    "description": "sibling $defs survive anyOf false collapse when they are local ref targets",
    "schema": {
      "allOf": [
        {
          "$ref": "#/x/$defs/A"
        }
      ],
      "x": {
        "anyOf": [
          false
        ],
        "$defs": {
          "A": {
            "type": "string"
          }
        }
      }
    }
  },
  {
    "description": "sibling $defs survive oneOf false collapse when they are local ref targets",
    "schema": {
      "allOf": [
        {
          "$ref": "#/x/$defs/A"
        }
      ],
      "x": {
        "oneOf": [
          false
        ],
        "$defs": {
          "A": {
            "type": "string"
          }
        }
      }
    }
  },
  {
    "description": "non-object enum values with object keywords stay representable",
    "schema": {
      "properties": {
        "x": true
      },
      "enum": [
        1
      ]
    }
  },
  {
    "description": "non-array enum values with array keywords stay representable",
    "schema": {
      "items": true,
      "enum": [
        1
      ]
    }
  },
  {
    "description": "non-string enum values with string keywords stay representable",
    "schema": {
      "minLength": 1,
      "enum": [
        1
      ]
    }
  }
]
